# ── AI layer (เลือกอย่างน้อย 1 อัน — ถ้าไม่ใส่ ระบบจะใช้สรุปแบบ template แทน) ──
# ลำดับความสำคัญ: OpenRouter → Anthropic → OpenAI

# OpenRouter (แนะนำ — เข้าถึงหลายโมเดลผ่าน key เดียว) จาก openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_MODEL_PREMIUM=openai/gpt-4o

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Server ──
PORT=3000

# ── Crawl limits ──
MAX_PAGES_DEFAULT=30
MAX_PAGES_LIMIT=100

# ── แจ้งเตือน LINE (Watchlist) — Messaging API จาก developers.line.biz ──
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=
