# ── AI layer (เลือกอย่างน้อย 1 อัน — ถ้าไม่ใส่ ระบบจะใช้สรุปแบบ template แทน) ──
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude) — ถ้าใส่จะใช้ Claude ก่อน OpenAI
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Server ──
PORT=3000

# ── Crawl limits ──
MAX_PAGES_DEFAULT=30
MAX_PAGES_LIMIT=100

# ── แจ้งเตือน LINE (Watchlist) — Messaging API จาก developers.line.biz ──
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=
